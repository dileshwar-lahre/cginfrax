{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/otherservices/layout,_N_T_/otherservices/page,_N_T_/otherservices"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/otherservices/__PAGE__",
    "/otherservices",
    "/_index",
    "/_head"
  ]
}