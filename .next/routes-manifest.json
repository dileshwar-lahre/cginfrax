        "regex": "^/rooms-in-bilaspur(?:/)?$"
      },
      {
        "source": "/rooms-in-raipur",
        "destination": "/listing?category=Room&district=Raipur",
        "regex": "^/rooms-in-raipur(?:/)?$"
