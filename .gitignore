# 1. Dependencies - Ye hamesha ignore honi chahiye
/node_modules
/.pnp
.pnp.*

# 2. Next.js Build Output - ISE COMMIT MAT KARO
# Hostinger par jaakar 'npm run build' chalana best hai
.next/
/out/
/build

# 3. Static Files & Cache
.vercel
*.tsbuildinfo
next-env.d.ts

# 4. Environment Variables (Security!)
# IMPORTANT: .env files ko hamesha ignore karo. 
# Hostinger ke dashboard mein ya terminal mein variables set karna safe hai.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# 5. Debug & OS Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
*.pem